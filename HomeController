using Microsoft.AspNetCore.Mvc;
using Studentdet.Models;
using System.Diagnostics;

namespace Students.Controllers
{
    public class HomeController : Controller
    {
        StudentdbContext db = new StudentdbContext();
        public IActionResult Index()
        {
            return View("Index" ,db.Students.ToList());
        }


        [HttpGet]
        public IActionResult Create()
        {

            return View("Create");
        }

        [HttpPost]
        public IActionResult Create(Student student)
        {
            db.Students.Add(student);
            db.SaveChanges();
            return Redirect("/Home/Index");
        }


        [HttpGet]
        public IActionResult Edit(int? id) 
        {
            Student studenttobeupdated = db.Students.Find(id);
            return View("Edit", studenttobeupdated);
        }


        [HttpPost]
        public IActionResult Edit(Student studentupdated)
        {
            Student student = db.Students.Find(studentupdated.Id);
            student.Name = studentupdated.Name;
            student.Email = studentupdated.Email;
            student.Dob = studentupdated.Dob;
            db.SaveChanges();
            return Redirect("/Home/Index");
        }


        public IActionResult Delete(int? id)
        {
            Student studenttodelte = db.Students.Find(id);
            db.Students.Remove(studenttodelte);
            db.SaveChanges();
            return Redirect("/Home/Index");
        }





    }
}
